<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pastebin Clone</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        margin: 0;
        background: #f5f7fb;
        color: #1f2937;
      }
      .container {
        max-width: 900px;
        margin: 40px auto;
        background: white;
        padding: 24px;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
      }
      h1 { margin-top: 0; }
      textarea {
        width: 100%;
        min-height: 220px;
        font-size: 15px;
        padding: 12px;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        resize: vertical;
        box-sizing: border-box;
      }
      .controls {
        display: flex;
        gap: 12px;
        margin-top: 12px;
        flex-wrap: wrap;
      }
      select, input[type="password"], button {
        padding: 10px 14px;
        border-radius: 8px;
        border: 1px solid #d1d5db;
        font-size: 14px;
      }
      button {
        background: #2563eb;
        color: white;
        border: none;
        cursor: pointer;
      }
      button:hover { background: #1d4ed8; }
      .share-box {
        margin-top: 20px;
        padding: 14px;
        border: 1px solid #bfdbfe;
        background: #eff6ff;
        border-radius: 8px;
      }
      .share-row {
        display: flex;
        gap: 8px;
        margin-top: 8px;
        flex-wrap: wrap;
      }
      input[type="password"] {
        flex: 1;
        min-width: 240px;
      }
      .error {
        color: #b91c1c;
        margin-top: 10px;
      }
      .success {
        color: #166534;
        margin-top: 10px;
      }
      .hint {
        margin-top: 8px;
        color: #475569;
        font-size: 14px;
      }
      .warning {
        color: #b45309;
        margin-top: 8px;
        font-size: 14px;
      }
      .checkbox-row {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>Pastebin Clone</h1>
      <p>Create a paste, get a shareable link, and copy it with one click.</p>

      <form id="pasteForm">
        <textarea id="pasteContent" name="content" placeholder="Type your text here..." required></textarea>

        <div class="controls">
          <label>
            Expiration
            <select name="expiration">
              <option value="never">Never</option>
              <option value="1m">1 minute</option>
              <option value="10m">10 minutes</option>
              <option value="1d">1 day</option>
              <option value="1w">1 week</option>
            </select>
          </label>

          <label>
            Visibility
            <select name="visibility">
              <option value="public">Public</option>
              <option value="unlisted">Unlisted</option>
            </select>
          </label>

          <label class="checkbox-row">
            <input type="checkbox" id="isSensitive" name="isSensitive" />
            Sensitive paste
          </label>

          <button type="submit">Save Paste</button>
        </div>

        <input id="passphrase" type="password" name="passphrase" placeholder="Passphrase for sensitive paste" hidden />
        <div id="sensitiveHint" class="hint" hidden>
          Sensitive pastes are encrypted in your browser before being sent. The passphrase is not stored in the database.
        </div>
        <div id="sensitiveWarning" class="warning" hidden>
          Keep the passphrase safe. Without it, the paste cannot be decrypted later.
        </div>
      </form>

      <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } %>

      <div id="statusMessage" class="success" aria-live="polite"></div>

      <div class="share-box" id="shareBox" hidden>
        <strong>Your paste is ready</strong>
        <div class="share-row">
          <input id="shareLink" value="" readonly />
          <button id="copyButton" type="button" onclick="copyLink()">Copy Link</button>
        </div>
      </div>
    </div>

    <script>
      const form = document.getElementById('pasteForm');
      const shareBox = document.getElementById('shareBox');
      const shareLink = document.getElementById('shareLink');
      const statusMessage = document.getElementById('statusMessage');
      const sensitiveToggle = document.getElementById('isSensitive');
      const passphraseInput = document.getElementById('passphrase');
      const sensitiveHint = document.getElementById('sensitiveHint');

      function toggleSensitiveFields() {
        const visible = sensitiveToggle.checked;
        passphraseInput.hidden = !visible;
        sensitiveHint.hidden = !visible;
        document.getElementById('sensitiveWarning').hidden = !visible;
        if (!visible) {
          passphraseInput.value = '';
        }
      }

      sensitiveToggle.addEventListener('change', toggleSensitiveFields);

      function arrayBufferToBase64(buffer) {
        let binary = '';
        const bytes = new Uint8Array(buffer);
        bytes.forEach((byte) => {
          binary += String.fromCharCode(byte);
        });
        return window.btoa(binary);
      }

      function base64ToArrayBuffer(base64) {
        const binary = window.atob(base64);
        const bytes = new Uint8Array(binary.length);
        for (let i = 0; i < binary.length; i += 1) {
          bytes[i] = binary.charCodeAt(i);
        }
        return bytes.buffer;
      }

      async function encryptText(text, passphrase) {
        const encoder = new TextEncoder();
        const salt = crypto.getRandomValues(new Uint8Array(16));
        const iv = crypto.getRandomValues(new Uint8Array(12));

        const keyMaterial = await crypto.subtle.importKey('raw', encoder.encode(passphrase), { name: 'PBKDF2' }, false, ['deriveKey']);
        const key = await crypto.subtle.deriveKey(
          { name: 'PBKDF2', salt, iterations: 250000, hash: 'SHA-256' },
          keyMaterial,
          { name: 'AES-GCM', length: 256 },
          false,
          ['encrypt']
        );

        const encrypted = await crypto.subtle.encrypt({ name: 'AES-GCM', iv }, key, encoder.encode(text));
        return {
          ciphertext: arrayBufferToBase64(encrypted),
          iv: arrayBufferToBase64(iv),
          salt: arrayBufferToBase64(salt),
        };
      }

      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        const content = document.getElementById('pasteContent').value.trim();
        const expiration = form.elements.expiration.value;
        const visibility = form.elements.visibility.value;
        const isSensitive = sensitiveToggle.checked;
        const passphrase = passphraseInput.value.trim();

        if (!content) {
          statusMessage.textContent = 'Please type some text before saving.';
          statusMessage.className = 'error';
          return;
        }

        if (isSensitive && !passphrase) {
          statusMessage.textContent = 'Please enter a passphrase for the sensitive paste.';
          statusMessage.className = 'error';
          return;
        }

        statusMessage.textContent = 'Saving paste...';
        statusMessage.className = 'success';

        try {
          let payload = { content, expiration, visibility, isSensitive };
          if (isSensitive) {
            const encrypted = await encryptText(content, passphrase);
            payload = {
              ...payload,
              content: encrypted.ciphertext,
              iv: encrypted.iv,
              salt: encrypted.salt,
            };
          }

          const response = await fetch('/api/pastes', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });

          const data = await response.json();

          if (!response.ok) {
            throw new Error(data.error || 'Unable to save paste.');
          }

          shareLink.value = data.shareUrl || `${window.location.origin}${data.url}`;
          shareBox.hidden = false;
          form.reset();
          toggleSensitiveFields();
          statusMessage.textContent = 'Paste saved successfully.';
          statusMessage.className = 'success';
        } catch (error) {
          statusMessage.textContent = error.message;
          statusMessage.className = 'error';
        }
      });

      function copyLink() {
        const input = document.getElementById('shareLink');
        const button = document.getElementById('copyButton');
        if (!input || !button) return;

        navigator.clipboard.writeText(input.value).then(() => {
          const originalText = button.textContent;
          button.textContent = 'Copied!';
          setTimeout(() => {
            button.textContent = originalText;
          }, 1200);
        });
      }
    </script>
  </body>
</html>
