<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Paste View</title>
    <style>
      :root {
        --bg: #f5f7fb;
        --surface: #ffffff;
        --text: #1f2937;
        --muted: #64748b;
        --border: #e2e8f0;
        --input-bg: #ffffff;
        --pre-bg: #f8fafc;
        --button-bg: #2563eb;
        --button-hover: #1d4ed8;
        --button-text: #ffffff;
        --shadow: 0 10px 30px rgba(0,0,0,0.08);
        --error: #b91c1c;
        --success: #166534;
      }

      body[data-theme="dark"] {
        --bg: #06070a;
        --surface: #111827;
        --text: #f9fafb;
        --muted: #cbd5e1;
        --border: #374151;
        --input-bg: #0f172a;
        --pre-bg: #0f172a;
        --button-bg: #3b82f6;
        --button-hover: #60a5fa;
        --button-text: #ffffff;
        --shadow: 0 12px 32px rgba(0,0,0,0.4);
        --error: #fca5a5;
        --success: #86efac;
      }

      body {
        font-family: Arial, sans-serif;
        margin: 0;
        min-height: 100vh;
        background: var(--bg);
        color: var(--text);
        transition: background 0.2s ease, color 0.2s ease;
      }
      .container {
        max-width: 900px;
        margin: 40px auto;
        background: var(--surface);
        padding: 24px;
        border-radius: 12px;
        box-shadow: var(--shadow);
        border: 1px solid var(--border);
      }
      .top-bar {
        display: flex;
        justify-content: flex-end;
        margin-bottom: 12px;
      }
      pre {
        white-space: pre-wrap;
        word-break: break-word;
        background: var(--pre-bg);
        padding: 16px;
        border-radius: 8px;
        border: 1px solid var(--border);
        color: var(--text);
      }
      .error {
        color: var(--error);
      }
      .success {
        color: var(--success);
      }
      .muted {
        color: var(--muted);
        font-size: 14px;
      }
      .controls {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 12px;
      }
      input, button {
        padding: 10px 12px;
        border-radius: 8px;
        border: 1px solid var(--border);
      }
      input {
        background: var(--input-bg);
        color: var(--text);
      }
      button {
        background: var(--button-bg);
        color: var(--button-text);
        border: none;
        cursor: pointer;
      }
      button:hover { background: var(--button-hover); }
      .theme-toggle {
        background: transparent;
        color: var(--text);
        border: 1px solid var(--border);
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="top-bar">
        <button id="themeToggle" class="theme-toggle" type="button">🌙 Night mode</button>
      </div>
      <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } else { %>
        <% const isEncrypted = Boolean(paste.encrypted || (paste.iv && paste.salt)); %>
        <h1>Paste</h1>
        <p><strong>ID:</strong> <%= paste.id %></p>

        <% if (isEncrypted) { %>
          <div id="decryptPanel">
            <p>This paste is encrypted and stored safely in the database.</p>
            <p class="muted">Enter the passphrase to reveal the content. The passphrase is never stored.</p>
            <div class="controls">
              <input id="passphraseInput" type="password" placeholder="Passphrase" />
              <button id="decryptButton" type="button">Decrypt</button>
            </div>
            <div id="decryptMessage" class="success"></div>
            <pre id="pasteContent" style="display: none;"></pre>
          </div>
        <% } else { %>
          <pre><%= paste.content %></pre>
        <% } %>
      <% } %>
    </div>

    <script>
      window.pasteData = <%= JSON.stringify(paste) %>;
      const themeToggle = document.getElementById('themeToggle');

      function applyTheme(theme) {
        document.body.dataset.theme = theme;
        localStorage.setItem('pasteTheme', theme);
        themeToggle.textContent = theme === 'dark' ? '☀️ Day mode' : '🌙 Night mode';
        themeToggle.setAttribute('aria-pressed', theme === 'dark' ? 'true' : 'false');
      }

      const savedTheme = localStorage.getItem('pasteTheme');
      applyTheme(savedTheme === 'dark' ? 'dark' : 'light');

      themeToggle.addEventListener('click', () => {
        const nextTheme = document.body.dataset.theme === 'dark' ? 'light' : 'dark';
        applyTheme(nextTheme);
      });

      function base64ToArrayBuffer(base64) {
        const binary = window.atob(base64);
        const bytes = new Uint8Array(binary.length);
        for (let i = 0; i < binary.length; i += 1) {
          bytes[i] = binary.charCodeAt(i);
        }
        return bytes.buffer;
      }

      async function decryptText(ciphertext, iv, salt, passphrase) {
        const encoder = new TextEncoder();
        const keyMaterial = await crypto.subtle.importKey('raw', encoder.encode(passphrase), { name: 'PBKDF2' }, false, ['deriveKey']);
        const key = await crypto.subtle.deriveKey(
          { name: 'PBKDF2', salt: base64ToArrayBuffer(salt), iterations: 250000, hash: 'SHA-256' },
          keyMaterial,
          { name: 'AES-GCM', length: 256 },
          false,
          ['decrypt']
        );

        const decrypted = await crypto.subtle.decrypt({ name: 'AES-GCM', iv: base64ToArrayBuffer(iv) }, key, base64ToArrayBuffer(ciphertext));
        return new TextDecoder().decode(decrypted);
      }

      const decryptButton = document.getElementById('decryptButton');
      if (decryptButton) {
        decryptButton.addEventListener('click', async () => {
          const passphrase = document.getElementById('passphraseInput').value;
          const message = document.getElementById('decryptMessage');
          const output = document.getElementById('pasteContent');

          if (!passphrase) {
            message.textContent = 'Please enter the passphrase.';
            message.className = 'error';
            return;
          }

          try {
            const content = await decryptText(window.pasteData.content, window.pasteData.iv, window.pasteData.salt, passphrase);
            output.textContent = content;
            output.style.display = 'block';
            message.textContent = 'Decrypted successfully.';
            message.className = 'success';
          } catch (error) {
            message.textContent = 'Unable to decrypt paste. Check the passphrase.';
            message.className = 'error';
          }
        });
      }
    </script>
  </body>
</html>
